# ---- Backend ----
# Postgres connection (async driver). Compose sets this for you; override in prod.
DATABASE_URL=postgresql+asyncpg://ideabrd:ideabrd@db:5432/ideabrd

# Secret used to sign the session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Google OAuth 2.0 credentials (https://console.cloud.google.com/apis/credentials).
# Leave BOTH empty to use the built-in dev login (a single shared local user) — handy for
# running the stack without setting up Google. Fill them in for real sign-in; the
# Authorized redirect URI must then be: <PUBLIC_URL>/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where Google sends the user back after login (must match the console + be reachable by the browser)
OAUTH_REDIRECT_URL=http://localhost:8000/api/auth/callback

# After a successful login, the browser is sent here (the SPA origin)
FRONTEND_URL=http://localhost:5173

# GitHub personal access token (read-only) for live repo data. Optional but recommended.
GITHUB_TOKEN=

# Set to true behind HTTPS so the session cookie gets the Secure flag
COOKIE_SECURE=false

# ---- Frontend (dev) ----
# Base path the SPA uses to reach the API. Empty = same origin (prod). Dev uses the Vite proxy.
VITE_API_BASE=
